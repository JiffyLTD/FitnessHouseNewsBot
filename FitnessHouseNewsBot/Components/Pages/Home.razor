@page "/"
@rendermode InteractiveServer

@using FitnessHouseNewsBot.Services
@using Microsoft.JSInterop

@inject UiLockService UiLockService
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager

<PageTitle>Доступ к FitnessHouse Bot</PageTitle>

<section class="lock-page">
    <div class="lock-card">
        <div class="lock-badge">Private UI</div>

        <h1>Введите пароль</h1>

        <p>
            Панель управления парсером закрыта. Пароль хранится в конфигурации
            приложения.
        </p>

        <form class="lock-form"
              @onsubmit="UnlockAsync"
              @onsubmit:preventDefault>
            <label for="password">Пароль</label>

            <input id="password"
                   type="password"
                   autocomplete="current-password"
                   autofocus
                   @bind="_password"
                   @bind:event="oninput" />

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <span class="lock-error">@_errorMessage</span>
            }

            <button type="submit"
                    disabled="@_isSubmitting">
                @(_isSubmitting ? "Проверяю..." : "Открыть панель")
            </button>
        </form>
    </div>
</section>

@code {
    private const string UiLockSessionKey = "fitness-house-news-bot-unlocked";

    private string _password = string.Empty;
    private string? _errorMessage;
    private bool _isSubmitting;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var isUnlocked = await JsRuntime.InvokeAsync<string?>(
            "fitnessHouseSession.get",
            UiLockSessionKey);

        if (string.Equals(
                isUnlocked,
                "true",
                StringComparison.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo("/dashboard");
        }
    }

    private async Task UnlockAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        if (!UiLockService.VerifyPassword(_password))
        {
            _errorMessage = "Неверный пароль";
            _isSubmitting = false;

            return;
        }

        await JsRuntime.InvokeVoidAsync(
            "fitnessHouseSession.set",
            UiLockSessionKey,
            "true");

        NavigationManager.NavigateTo("/dashboard");
    }
}
